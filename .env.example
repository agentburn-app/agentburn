# Database (MySQL)
DATABASE_URL="mysql://user:password@hostname:3306/agentburn"

# API Authentication (used to secure the ingest endpoint)
API_KEY="your-api-key-here"

# Optional: Budget alert webhook (Slack, Discord, etc.)
ALERT_WEBHOOK_URL=""

# Google Analytics (optional) — get your ID from https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Canonical site URL for SEO meta tags
NEXT_PUBLIC_SITE_URL="https://agentburn.dev"

# JWT secret for session tokens (generate with: openssl rand -base64 32)
JWT_SECRET=""

# Stripe (required for Pro subscriptions)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""
